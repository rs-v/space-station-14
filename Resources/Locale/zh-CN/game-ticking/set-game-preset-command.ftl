set-game-preset-command-description = 为指定数量的后续轮次设置游戏预设。也可以在大厅中显示另一个预设的标题和描述以迷惑玩家。
set-game-preset-command-help-text = setgamepreset <id> [轮次数量，默认为1] [诱骗预设]
set-game-preset-command-hint-1 = <id>
set-game-preset-command-hint-2 = [轮次数量]
set-game-preset-command-hint-3 = [诱骗预设]

set-game-preset-optional-argument-not-integer = 如果提供了参数2，它必须是一个数字。
set-game-preset-preset-error = 找不到游戏预设"{$preset}"
set-game-preset-decoy-error = 如果提供了参数3，它必须是一个有效的预设。找不到游戏预设"{$preset}"

#set-game-preset-preset-set = 已将游戏预设设置为"{$preset}"
set-game-preset-preset-set-finite = 已将游戏预设设置为"{$preset}"，将持续 {$rounds} 轮。
set-game-preset-preset-set-finite-with-decoy = 已将游戏预设设置为"{$preset}"，将持续 {$rounds} 轮，并在大厅中显示 {$decoy}。
