# addaction
cmd-addaction-desc = 向目标实体添加一个动作。如果目标需要额外组件（如龙的吞噬），该动作将无法使用。
cmd-addaction-help = addaction <实体Uid> <动作原型>

cmd-addaction-invalid-args = 需要恰好 2 个参数。
cmd-addaction-actions-not-found = 目标实体无法使用动作。
cmd-addaction-action-not-found = 找不到匹配的动作原型 {$action}。
cmd-addaction-adding-failed = 添加动作失败。

cmd-addaction-player-completion = <实体Uid>
cmd-addaction-action-completion = <动作原型>
