### EmitterComponent

# 尝试在没有适当访问权限的情况下开关发射器时显示
comp-emitter-access-locked = {$target}已被访问锁定！

# 开关发射器时显示
comp-emitter-turned-on = {$target}已开启。

comp-emitter-turned-off = {$target}已关闭。

# 用户尝试激活未固定的发射器时显示
comp-emitter-not-anchored = {$target}未固定在地面上！

emitter-component-current-type = 当前选择的类型为：[color=yellow]{$type}[/color]。
emitter-component-type-set = 类型已设置为：{$type}

emitter-destroyed-broadcast = {$location}处的一台已通电发射器被摧毁。
emitter-deconstructed-broadcast = {$location}处的一台已通电发射器被拆除。
emitter-unlocked-broadcast = {$location}处的一台已通电发射器已解锁。
emitter-unpowered-broadcast = {$location}处的一台已通电发射器断电。
