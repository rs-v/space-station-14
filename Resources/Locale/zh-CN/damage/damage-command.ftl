## 伤害命令本地化。

damage-command-description = 对实体增加或减少伤害。
damage-command-help = 用法：{$command} <类型/组> <数量> [忽略抗性] [uid]

damage-command-arg-type = <伤害类型或组>
damage-command-arg-quantity = [数量]
damage-command-arg-target = [目标实体 euid]

damage-command-error-type = {$arg} 不是有效的伤害组或类型。
damage-command-error-euid = {$arg} 不是有效的实体 uid。
damage-command-error-quantity = {$arg} 不是有效的数量。
damage-command-error-bool = {$arg} 不是有效的布尔值。
damage-command-error-player = 会话中没有绑定实体。你必须指定目标 uid
damage-command-error-args = 参数数量无效
