# 名称
loadout-name-edit-label = 设置一个自定义名称，在你扮演此职位时使用。如果为空，将使用你的角色名称。
loadout-name-edit-label-dataset = 设置一个自定义名称，在你扮演此职位时使用。如果为空，将随机选择一个名称。
loadout-name-edit-tooltip = 最多{$max}个字符。如果未指定名称，可能会为你随机选择一个。

# 限制
loadout-restrictions = 限制条件
loadouts-min-limit = 最少数量：{$count}
loadouts-max-limit = 最多数量：{$count}
loadouts-points-limit = 点数：{$count} / {$max}

loadouts-count-items-in-group = {$item}和另外{$count}件{$count ->
[1] 物品
*[other] 物品
}

loadouts-points-restriction = 点数不足
