cmd-announce-desc = 发送带有自定义颜色和声音的游戏内公告。
cmd-announce-help = {$command} <消息> [发送人] [颜色] [声音] - 发送公告。发送人默认为中央指挥，颜色默认为金色，声音默认为announce.ogg。颜色应为#RRGGBB格式。

# 公告的默认发送人
cmd-announce-sender = 中央指挥

# 补全提示
cmd-announce-arg-message = <消息>
cmd-announce-arg-sender = [发送人]
cmd-announce-arg-color = [颜色]
cmd-announce-arg-sound = [声音]
