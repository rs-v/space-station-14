# 命令
## 延迟飞船结束轮次
cmd-delayroundend-desc = 停止紧急飞船离开超空间时结束轮次的计时器。
cmd-delayroundend-help = 用法：delayroundend
emergency-shuttle-command-round-yes = 轮次已延迟。
emergency-shuttle-command-round-no = 无法延迟轮次结束。

## 停靠紧急飞船
cmd-dockemergencyshuttle-desc = 呼叫紧急飞船并将其停靠到站点……如果可以的话。
cmd-dockemergencyshuttle-help = 用法：dockemergencyshuttle

## 发射紧急飞船
cmd-launchemergencyshuttle-desc = 如果可能，提前发射紧急飞船。
cmd-launchemergencyshuttle-help = 用法：launchemergencyshuttle

# 紧急飞船
emergency-shuttle-left = 紧急飞船已离开站点。预计 {$transitTime} 秒后到达中央指挥部。
emergency-shuttle-launch-time = 紧急飞船将在 {$consoleAccumulator} 秒后发射。
emergency-shuttle-docked = 紧急飞船已停靠在站点{$direction}，{$location}。将在 {$time} 秒后离开。{$extended}
emergency-shuttle-good-luck = 紧急飞船无法找到站点。祝你好运。
emergency-shuttle-nearby = 紧急飞船无法找到有效停靠口。已在站点{$direction}，{$location}附近出现。将在 {$time} 秒后离开。{$extended}
emergency-shuttle-extended = {" "}由于不便的情况，发射时间已延长。

# 紧急飞船控制台弹窗/广播
emergency-shuttle-console-no-early-launches = 提前发射已禁用
emergency-shuttle-console-auth-left = 还需 {$remaining} 个授权才能提前发射飞船。
emergency-shuttle-console-auth-revoked = 提前发射授权已撤销，还需 {$remaining} 个授权。
emergency-shuttle-console-denied = 访问被拒绝

