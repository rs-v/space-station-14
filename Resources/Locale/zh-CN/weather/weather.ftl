cmd-weatherremove-desc = 从地图中移除特定天气。
cmd-weatherset-desc = 移除除指定天气外的所有天气。如果指定的天气在地图上不存在，则添加它。
cmd-weatheradd-desc = 向地图添加特定天气。

cmd-weatherremove-help = weatherremove <地图ID> <原型>
cmd-weatherset-help = weatherset <地图ID> <原型 / null>
cmd-weatheradd-help = weatheradd <地图ID> <原型 / null>

cmd-weather-error-no-arguments = 参数不足！
cmd-weather-error-unknown-proto = 未知的天气原型！
cmd-weather-error-wrong-time = 时间格式错误！
cmd-weather-error-wrong-map = 地图ID为{$id}的地图不存在！
cmd-weather-error-no-weather = 所选地图上不存在该天气！

cmd-weather-hint-map-id = 地图ID
cmd-weather-hint-prototype = 天气实体原型
cmd-weather-hint-time = 持续时间（秒）（留空表示永久）
