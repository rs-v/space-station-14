cmd-weatherremove-desc = 从地图中移除指定天气。
cmd-weatherset-desc = 移除所有天气，只保留指定的那种。如果指定的天气不存在于地图上，则添加它。
cmd-weatheradd-desc = 向地图添加指定天气。

cmd-weatherremove-help = weatherremove <地图ID> <原型>
cmd-weatherset-help = weatherset <地图ID> <原型/null>
cmd-weatheradd-help = weatheradd <地图ID> <原型/null>

cmd-weather-error-no-arguments = 参数不足！
cmd-weather-error-unknown-proto = 未知天气原型！
cmd-weather-error-wrong-time = 时间格式错误！
cmd-weather-error-wrong-map = MapId为{$id}的地图不存在！
cmd-weather-error-no-weather = 选定地图上不存在此天气！

cmd-weather-hint-map-id = 地图ID
cmd-weather-hint-prototype = 天气实体原型
cmd-weather-hint-time = 持续时间（秒）（留空表示无限时长）
